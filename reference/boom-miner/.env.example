# ============================================================
# BOOM MINER — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority


# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------

# Secret used to sign and verify JWT session tokens.
# Generate with: openssl rand -base64 32
JWT_SECRET=


# ------------------------------------------------------------
# Blockchain
# ------------------------------------------------------------

# Chain to use: solana | robinhood | hive  (default: solana)
# Use NEXT_PUBLIC_CHAIN so it is readable on both server and client.
# CHAIN is the server-only fallback — only set one of the two.
NEXT_PUBLIC_CHAIN=solana
# CHAIN=solana

# Smart contract / program address for the game NFT collection
CONTRACT_ADDRESS=

# Treasury wallet address that receives fees / minting payments
TREASURY_ADDRESS=

# Private key of the treasury wallet (server-only, never expose to client)
# Accepts base58 (Phantom export) or a JSON byte array "[12,34,...]".
TREASURY_KEY=

# Public Solana JSON-RPC endpoint used by the BROWSER deposit flow. Keep this a
# plain public endpoint (no secret) — it is exposed to the client. Point to a
# devnet URL for testing.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key (SERVER-ONLY). Used to build a reliable RPC endpoint for
# on-chain transaction verification and treasury payouts. When set, the server
# talks to https://mainnet.helius-rpc.com/?api-key=... (devnet auto-detected
# from SOLANA_RPC_URL). Never exposed to the client. Get one at helius.dev.
HELIUS_API_KEY=

# NOTE: The SPL mint the treasury pays out is the generic CONTRACT_ADDRESS
# above, and token decimals are hardcoded to 9 in lib/config/config.ts — there
# are no separate SOLANA_MINT_ADDRESS / SOLANA_TOKEN_DECIMALS vars.

# NOTE: There is no withdrawal daily limit for now, and the settlement worker's
# poll interval and retry ceiling are hardcoded in lib/config/config.ts — none
# of those are environment-configurable.


# ------------------------------------------------------------
# WebSocket Engine  (server/game-websocket-engine)
# Set on the VPS running the WS server via Coolify.
# ------------------------------------------------------------

# Port the Socket.IO server listens on (default: 4000)
PORT=4000

# Allowed CORS origin — set to your Vercel app domain in production
CORS_ORIGIN=https://your-app.vercel.app


# ------------------------------------------------------------
# Client — WebSocket connection
# Set on the Next.js app (Vercel).
# When set, the Phaser client connects via WebSocket instead
# of the fallback HTTP polling sync.
# ------------------------------------------------------------

# Full URL of the running WebSocket engine (https, no trailing slash)
NEXT_PUBLIC_WS_URL=https://ws.your-domain.com
