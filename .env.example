# ============================================================
# IDLE RAIDERS — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# MongoDB connection string (required)
# In production both vars point to the same Atlas cluster.
# In local dev, MONGO_URI_LOCAL can point to a local/dev cluster.
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI_LOCAL=mongodb://localhost:27017/idleraiders


# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------

# Secret used to sign and verify JWT session tokens.
# Generate with: openssl rand -base64 32
JWT_SECRET=


# ------------------------------------------------------------
# Blockchain
# ------------------------------------------------------------

# Chain to use: solana | robinhood | hive  (default: solana)
# Use NEXT_PUBLIC_CHAIN so it is readable on both server and client.
# CHAIN is the server-only fallback — only set one of the two.
NEXT_PUBLIC_CHAIN=solana
# CHAIN=solana

# Smart contract / program address for the game NFT / token collection
CONTRACT_ADDRESS=

# Treasury wallet address that receives fees / minting payments
TREASURY_ADDRESS=

# Private key of the treasury wallet (server-only, NEVER expose to client)
# Solana: accepts base58 (Phantom export) or a JSON byte array "[12,34,...]"
# Hive: leave blank — use HIVE_ACTIVE_KEY below instead
TREASURY_KEY=


# ---- Solana ------------------------------------------------------------------

# Public Solana JSON-RPC endpoint used by the BROWSER deposit flow.
# Keep this a plain public endpoint (no secret) — it is exposed to the client.
# Point to a devnet URL for testing.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key (SERVER-ONLY). Used to build a reliable RPC endpoint for
# on-chain transaction verification and treasury payouts.
# Never exposed to the client. Get one at helius.dev.
HELIUS_API_KEY=


# ---- Robinhood (EVM) ---------------------------------------------------------

ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com/
ROBINHOOD_CHAIN_ID=4663
# ERC-20 token contract. Falls back to CONTRACT_ADDRESS if blank.
ROBINHOOD_TOKEN_ADDRESS=
ROBINHOOD_TOKEN_DECIMALS=18


# ---- Hive / Hive-Engine ------------------------------------------------------

# Comma-separated list of Hive API nodes for consensus-layer broadcast.
HIVE_RPC_NODES=https://api.hive.blog,https://api.hivekings.com

# Hive-Engine (layer-2) sidechain RPC and custom_json sidechain ID.
HIVE_ENGINE_RPC_URL=https://api.hive-engine.com/rpc
HIVE_ENGINE_ID=ssc-mainnet-hive

# Hive-Engine token symbol the treasury pays out. Falls back to CONTRACT_ADDRESS.
HIVE_TOKEN_SYMBOL=
# Token precision (decimal places) as configured on Hive-Engine.
HIVE_TOKEN_PRECISION=8

# Active key of the game treasury Hive account (SERVER-ONLY).
# Used to broadcast custom_json and transfer operations.
HIVE_ACTIVE_KEY=

# Game account name on Hive (used for Hive-Engine broadcasts / memo lookups).
GAME_ACCOUNT_NAME=idleraiders


# ------------------------------------------------------------
# Game Economy
# ------------------------------------------------------------

# In-game pack / fee prices (whole-token amounts before decimals).
# These override the hardcoded constants in constants/game.ts.

# Hero pack price in game tokens (default: 500000)
PACK_PRICE_HEROES=500000

# Registration fee in game tokens (default: 1000)
REGISTRATION_FEE=1000


# ------------------------------------------------------------
# WebSocket Engine  (server/server.ts)
# Set on the VPS running the WS server via Coolify / PM2.
# ------------------------------------------------------------

# Port the Socket.IO server listens on (default: 5000)
PORT=5000

# Allowed CORS origin — set to your Vercel app domain in production
CORS_ORIGIN=https://your-app.vercel.app


# ------------------------------------------------------------
# Client — Server & WebSocket connection
# Set on the Next.js app (Vercel).
# ------------------------------------------------------------

# Full URL of the running game server (https, no trailing slash).
# Used by GameContext for REST calls (player state, price, etc.)
NEXT_PUBLIC_SERVER_URL=http://localhost:5000

# Full URL of the running WebSocket engine (https, no trailing slash).
# When set, the game client connects via WebSocket instead of HTTP polling.
# Defaults to NEXT_PUBLIC_SERVER_URL if not set separately.
NEXT_PUBLIC_WS_URL=https://ws.your-domain.com

# Optional: separate socket URL for the background worker socket.
# Falls back to NEXT_PUBLIC_SERVER_URL when not set.
NEXT_PUBLIC_WORKER_SOCKET_URL=


# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------

# Set to 'true' to enable the in-game wallet deposit/withdraw UI.
# When 'false' (default), the wallet tab is hidden for all players.
NEXT_PUBLIC_WALLET_ENABLED=false

# Set to 'true' to replace the entire app with the Maintenance page.
# Toggle by updating this var and redeploying (no code change needed).
NEXT_PUBLIC_IS_MAINTENANCE=false
