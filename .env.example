# ============================================================
# IDLE RAIDERS — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================


# ------------------------------------------------------------
# Database
# ------------------------------------------------------------

# MongoDB connection string (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority


# ------------------------------------------------------------
# Auth
# ------------------------------------------------------------

# Secret used to sign and verify JWT session tokens.
# Generate with: openssl rand -base64 32
JWT_SECRET=


# ------------------------------------------------------------
# Blockchain
# ------------------------------------------------------------

# Chain to use: solana | robinhood | hive  (default: solana)
# Use NEXT_PUBLIC_CHAIN so it is readable on both server and client.
# CHAIN is the server-only fallback — only set one of the two.
NEXT_PUBLIC_CHAIN=solana
# CHAIN=solana

# Smart contract / program address for the game NFT / token collection
CONTRACT_ADDRESS=

# Treasury wallet address that receives fees / minting payments
TREASURY_ADDRESS=

# Private key of the treasury wallet (server-only, NEVER expose to client)
# Solana: accepts base58 (Phantom export) or a JSON byte array "[12,34,...]"
# Hive: this same key is used as the Hive active key — no separate HIVE_ACTIVE_KEY needed
# Robinhood (EVM): this same key is used as the EVM wallet private key
TREASURY_KEY=


# ---- Solana ------------------------------------------------------------------
# rpcUrl is hardcoded to https://api.mainnet-beta.solana.com — no env var needed.

# Helius API key (SERVER-ONLY). Used to build a reliable RPC endpoint for
# on-chain transaction verification and treasury payouts.
# Never exposed to the client. Get one at helius.dev.
HELIUS_API_KEY=


# ---- Robinhood (EVM) ---------------------------------------------------------
# RPC URL, chain ID (4663), and token decimals (18) are hardcoded constants.
# CONTRACT_ADDRESS is used as the ERC-20 token contract — no extra var needed.


# ---- Hive / Hive-Engine ------------------------------------------------------
# All Hive constants are hardcoded — no env vars needed:
#   rpcNodes:     api.hive.blog, api.hivekings.com, anyx.io, hived.privex.io
#   engineRpcUrl: https://api.hive-engine.com/rpc
#   engineId:     ssc-mainnet-hive
#   tokenSymbol:  CONTRACT_ADDRESS
#   precision:    8
#   activeKey:    TREASURY_KEY
#   account:      TREASURY_ADDRESS


# ------------------------------------------------------------
# Game Economy
# ------------------------------------------------------------

# In-game pack / fee prices (whole-token amounts before decimals).
# These override the hardcoded constants in constants/game.ts.

# Hero pack price in game tokens (default: 500000)
PACK_PRICE_HEROES=10000

# ------------------------------------------------------------
# Drain Worker  (server/server.ts)
# Set on the VPS running the worker process via Coolify / PM2.
# ------------------------------------------------------------

# Port the health-check HTTP server listens on (default: 5000)
PORT=5000

# Allowed CORS origin — set to your Vercel app domain in production
CORS_ORIGIN=https://your-app.vercel.app


# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------

# Set to 'true' to enable the in-game wallet deposit/withdraw UI.
# When 'false' (default), the wallet tab is hidden for all players.
NEXT_PUBLIC_WALLET_ENABLED=false

# Set to 'true' to replace the entire app with the Maintenance page.
# Toggle by updating this var and redeploying (no code change needed).
NEXT_PUBLIC_IS_MAINTENANCE=false
